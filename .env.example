# ─── Sales Lead Qualifier ───
# Copy this file to .env.local and fill in the values you need.

# ─── Webhook (optional) ───
# Form submissions from /book and /guide are forwarded here as JSON.
# If not set, submissions succeed for the user but data is only logged
# to the server console (not persisted anywhere).
# WEBHOOK_URL=https://your-webhook-endpoint.com/lead

# ─── Visual Effects ───
# Set to "false" to disable the floating glitter/sparkle background effect.
# The celebration burst on the result page for qualified leads is separate
# and always plays regardless of this setting.
# Default: true (glitter enabled)
NEXT_PUBLIC_ENABLE_GLITTER=true
